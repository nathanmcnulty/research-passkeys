{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://research-passkeys/contracts/stored-credential-record.schema.json",
  "title": "StoredCredentialRecord",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "recordId",
    "credentialId",
    "rpId",
    "userHandle",
    "userName",
    "userDisplayName",
    "signingKeyId",
    "backendKind",
    "createdAt",
    "updatedAt",
    "signCount"
  ],
  "properties": {
    "recordId": {
      "type": "string",
      "minLength": 1
    },
    "credentialId": {
      "type": "string",
      "minLength": 1,
      "description": "Base64url-encoded credential identifier."
    },
    "rpId": {
      "type": "string",
      "minLength": 1
    },
    "userHandle": {
      "type": "string",
      "minLength": 1,
      "description": "Base64url-encoded user handle."
    },
    "userName": {
      "type": "string",
      "minLength": 1
    },
    "userDisplayName": {
      "type": "string",
      "minLength": 1
    },
    "signingKeyId": {
      "type": "string",
      "minLength": 1
    },
    "backendKind": {
      "type": "string",
      "minLength": 1
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "signCount": {
      "type": "integer",
      "minimum": 0
    }
  }
}
