{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://research-passkeys/contracts/passkey-login-credential.schema.json",
  "title": "PasskeyLoginCredential",
  "type": "object",
  "additionalProperties": false,
  "$comment": "New writers should prefer userName + relyingParty + signCount. Existing aliases remain valid for backward-compatible readers.",
  "required": [
    "credentialId",
    "userHandle"
  ],
  "allOf": [
    {
      "anyOf": [
        {
          "required": [
            "userName"
          ]
        },
        {
          "required": [
            "username"
          ]
        },
        {
          "required": [
            "userPrincipalName"
          ]
        }
      ]
    },
    {
      "anyOf": [
        {
          "required": [
            "relyingParty"
          ]
        },
        {
          "required": [
            "rpId"
          ]
        }
      ]
    },
    {
      "anyOf": [
        {
          "required": [
            "keyVault"
          ]
        },
        {
          "required": [
            "privateKey"
          ]
        },
        {
          "required": [
            "keyValue"
          ]
        }
      ]
    }
  ],
  "properties": {
    "credentialId": {
      "type": "string",
      "minLength": 1,
      "description": "FIDO2 credential ID. Readers accept base64url or UUID form."
    },
    "userHandle": {
      "type": "string",
      "minLength": 1,
      "description": "Base64url-encoded FIDO2 user handle."
    },
    "userName": {
      "type": "string",
      "minLength": 1,
      "description": "Canonical sign-in name for passkey login."
    },
    "username": {
      "type": "string",
      "minLength": 1,
      "description": "Backward-compatible alias for userName."
    },
    "userPrincipalName": {
      "type": "string",
      "minLength": 1,
      "description": "Backward-compatible alias for userName."
    },
    "relyingParty": {
      "type": "string",
      "minLength": 1,
      "description": "Canonical RP ID for login, such as login.microsoft.com."
    },
    "rpId": {
      "type": "string",
      "minLength": 1,
      "description": "Backward-compatible alias for relyingParty."
    },
    "url": {
      "type": "string",
      "minLength": 1,
      "description": "Origin URL used for WebAuthn clientData."
    },
    "signCount": {
      "type": "integer",
      "minimum": 0,
      "description": "Canonical signature counter. Readers default to 0 when omitted."
    },
    "counter": {
      "type": "integer",
      "minimum": 0,
      "description": "Backward-compatible alias for signCount."
    },
    "displayName": {
      "type": "string"
    },
    "createdDateTime": {
      "type": "string",
      "format": "date-time"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "keyVault": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "vaultName",
        "keyName"
      ],
      "properties": {
        "vaultName": {
          "type": "string",
          "minLength": 1
        },
        "keyName": {
          "type": "string",
          "minLength": 1
        },
        "keyId": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "privateKey": {
      "type": "string",
      "minLength": 1,
      "description": "PEM or base64 private key for local signing."
    },
    "keyValue": {
      "type": "string",
      "minLength": 1,
      "description": "Backward-compatible alias for privateKey."
    }
  }
}
