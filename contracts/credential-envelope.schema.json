      "type": "string",
      "minLength": 1
    },
    "recordId": {
      "type": "string",
      "minLength": 1
    },
    "contentKeyProtection": {
      "type": "string",
      "minLength": 1
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "ciphertext": {
      "type": "string",
      "minLength": 1
    },
    "protectedContentKey": {
      "type": "string",
      "minLength": 1
    },
    "metadataKeyId": {
      "type": [
        "string",
        "null"
