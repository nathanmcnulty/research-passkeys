    "nonce": {
      "type": "string",
      "minLength": 1
    },
    "tag": {
      "type": "string",
      "minLength": 1
    },
    "tenantId": {
      "type": [
        "string",
        "null"
      ]
    },
    "userObjectId": {
      "type": [
        "string",
        "null"
      ]
    },
    "credentialId": {
      "type": [
        "string",
        "null"
      ]
    },
    "rpId": {
      "type": [
        "string",
        "null"
      ]
    },
    "userHandle": {
      "type": [
        "string",
        "null"
      ]
    },
    "signingKeyId": {
      "type": [
        "string",
        "null"
      ]
    },
    "backendKind": {
      "type": [
        "string",
        "null"
      ]
    }
  }
