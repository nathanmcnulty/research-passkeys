{
  "bindings": [
    {
      "authLevel": "function",
      "type": "httpTrigger",
      "direction": "in",
      "name": "Request",
      "methods": [
        "post"
      ],
      "route": "okta/passkeys/register/idx/queue"
    },
    {
      "type": "http",
      "direction": "out",
      "name": "Response"
    },
    {
      "type": "queue",
      "direction": "out",
      "name": "RegistrationMessage",
      "queueName": "%PASSKEY_OKTA_REGISTRATION_QUEUE_NAME%",
      "connection": "AzureWebJobsStorage"
    }
  ]
}
