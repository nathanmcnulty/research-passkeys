{
  "manifest_version": 3,
  "name": "Key Vault Passkey Provider",
  "version": "0.1.0",
  "key": "",
  "description": "Experimental Azure Key Vault-backed passkey extension scaffold.",
  "permissions": ["storage", "identity", "windows", "activeTab", "scripting", "sidePanel", "declarativeNetRequestWithHostAccess"],
  "optional_host_permissions": ["http://*/*", "https://*/*"],
  "background": {
    "service_worker": "background.js"
  },
  "options_ui": {
    "page": "setup.html",
    "open_in_tab": true
  },
  "action": {
    "default_title": "Open Key Vault Passkey Provider"
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "web_accessible_resources": [
    {
      "resources": ["page.js"],
      "matches": ["http://*/*", "https://*/*"]
    }
  ]
}
